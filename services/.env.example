# Ollama server (shared across all services)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_TIMEOUT=120

# API authentication (all services)
API_KEY=change-me-in-production

# UC-04 PostgreSQL (pgvector)
POSTGRES_DSN=postgresql://pguser:pgpass@postgres:5432/breeddb

# Redis (idempotency cache)
REDIS_URL=redis://redis:6379/0

# UC-05 / UC-06 job store
JOB_STORE_URL=redis://redis:6379/1
